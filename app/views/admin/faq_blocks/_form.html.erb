<%= form_with model: [@page, faq_block], local: true do |f| %>
  <% if faq_block.errors.any? %>
    <div class="flash flash--alert" style="margin-bottom:1rem">
      <ul style="margin:0;padding-left:1.25rem">
        <% faq_block.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field-unit">
    <%= f.label :question, "Question" %>
    <%= f.text_field :question, class: "input", placeholder: "e.g. What formats are supported?" %>
    <p class="field-unit__hint">The question shown to users and indexed in FAQ structured data.</p>
  </div>

  <div class="field-unit">
    <%= f.label :answer, "Answer" %>
    <%= f.text_area :answer, class: "input", rows: 4, placeholder: "Plain text answer (no HTML)." %>
    <p class="field-unit__hint">Keep answers concise. Appears in Google FAQ rich results and AI summaries.</p>
  </div>

  <div class="field-unit" style="max-width:100px">
    <%= f.label :position, "Order" %>
    <%= f.number_field :position, class: "input", min: 0 %>
  </div>

  <div style="margin-top:1.5rem; display:flex; gap:.75rem">
    <%= f.submit faq_block.new_record? ? "Add FAQ Item" : "Save Changes", class: "button" %>
    <%= link_to "Cancel", admin_page_faq_blocks_path(@page), class: "button button--alt" %>
  </div>
<% end %>
