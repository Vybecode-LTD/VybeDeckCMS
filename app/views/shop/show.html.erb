<% content_for :title, "#{@product.name} | Shop | VybeDeck CMS" %>
<% content_for :description, @product.description if @product.respond_to?(:description) && @product.description.present? %>
<% if @product.cover_image.attached? %>
  <% content_for :og_image, url_for(@product.cover_image) %>
<% end %>
<% content_for :json_ld do %>
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Product",
      "name": "<%= j @product.name %>"<% if @product.description.present? %>,
      "description": "<%= j @product.description %>"<% end %><% if @product.cover_image.attached? %>,
      "image": "<%= j url_for(@product.cover_image) %>"<% end %><% if @price %>,
      "offers": {
        "@type": "Offer",
        "priceCurrency": "<%= j @price.currency.upcase %>",
        "price": "<%= "%.2f" % (@price.amount_cents / 100.0) %>",
        "availability": "https://schema.org/InStock",
        "url": "<%= j request.url %>"
      }<% end %>
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "<%= j root_url %>" },
        { "@type": "ListItem", "position": 2, "name": "Shop", "item": "<%= j shop_url %>" },
        { "@type": "ListItem", "position": 3, "name": "<%= j @product.name %>", "item": "<%= j request.url %>" }
      ]
    }
  ]
}
<% end %>

<main class="page-shell">
  <article class="product-detail">
    <div class="shell product-detail__inner">

      <div class="product-detail__media">
        <% if @product.cover_image.attached? %>
          <%= image_tag url_for(@product.cover_image),
                alt: @product.name,
                class: "product-detail__cover" %>
        <% else %>
          <div class="product-detail__cover product-detail__cover--placeholder" aria-hidden="true">
            <span>&#9835;</span>
          </div>
        <% end %>
      </div>

      <div class="product-detail__info">
        <% unless @product.active? %>
          <span class="status-pill status-pill--draft">
            <%= @product.status.capitalize %>
          </span>
        <% end %>

        <h1><%= @product.name %></h1>

        <% if @price %>
          <p class="product-detail__price"><%= @product.display_price %></p>
        <% else %>
          <p class="product-detail__price product-detail__price--free">Free</p>
        <% end %>

        <% if @product.description.present? %>
          <div class="product-detail__description">
            <%= simple_format(@product.description) %>
          </div>
        <% end %>

        <div class="product-detail__actions">
          <% if @price %>
            <%= button_to "Add to Cart",
                  cart_items_path(product_id: @product.slug),
                  method: :post,
                  class: "btn" %>
          <% else %>
            <button class="btn" disabled>Add to Cart</button>
          <% end %>
          <%= link_to "Buy Now", checkout_path, class: "btn btn--secondary" %>
        </div>
        <p class="product-detail__coming-soon">
          Secure checkout coming soon.
        </p>

        <%= link_to "← Back to Shop", shop_path, class: "link product-detail__back" %>
      </div>

    </div>
  </article>
</main>
