<% content_for :title, public_page_title(@post) %>
<% content_for :description, @post.meta_description.presence || @post.excerpt.to_s %>
<% content_for :og_type, "article" %>
<% if @post.cover_image.attached? %>
  <% content_for :og_image, url_for(@post.cover_image) %>
<% end %>
<% content_for :json_ld do %>
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "<%= j(@post.meta_title.presence || @post.title) %>",
  "description": "<%= j(@post.meta_description.presence || @post.excerpt.to_s) %>",
  "author": { "@type": "Person", "name": "<%= j @post.author.display_name %>" },
  "datePublished": "<%= @post.published_at&.iso8601 %>",
  "dateModified": "<%= @post.updated_at.iso8601 %>"<% if @post.cover_image.attached? %>,
  "image": "<%= j url_for(@post.cover_image) %>"<% end %>
}
<% end %>

<main class="page-shell">
  <article>
    <header class="content-hero">
      <div class="shell content-hero__grid">
        <div class="content-hero__copy">
          <div class="eyebrow">
            <%= readable_date(@post.published_at || @post.created_at) %>
            <% unless @post.published? %>
              <span class="status-pill"><%= published_label(@post) %></span>
            <% end %>
          </div>
          <h1><%= @post.title %></h1>
          <% if @post.excerpt.present? %>
            <p class="lede"><%= @post.excerpt %></p>
          <% end %>
          <p class="byline">
            <%= @post.author.byline %>
            &middot; <%= @post.reading_time %>&nbsp;min&nbsp;read
          </p>
          <% if @post.series %>
            <p class="series-badge">
              Part of:
              <%= link_to @post.series.title, series_path(@post.series), class: "link" %>
              <% if @post.series_position %>
                &middot; #<%= @post.series_position %>
              <% end %>
            </p>
          <% end %>
          <% if @post.categories.any? %>
            <div class="topic-list" aria-label="Topics">
              <% @post.categories.each do |category| %>
                <%= link_to category.name, category_path(category), class: "topic-chip" %>
              <% end %>
            </div>
          <% end %>
        </div>

        <% if @post.cover_image.attached? %>
          <figure class="feature-media">
            <%= image_tag url_for(@post.cover_image), alt: "" %>
          </figure>
        <% end %>
      </div>
    </header>

    <section class="content-band">
      <div class="shell reading-width trix-content">
        <%= @post.body %>
      </div>
    </section>

    <% if @related_posts.any? %>
      <section class="content-band content-band--muted">
        <div class="shell">
          <h2 class="section-heading">Related posts</h2>
          <div class="post-grid post-grid--compact">
            <% @related_posts.each do |post| %>
              <%= render "posts/post_card", post: post %>
            <% end %>
          </div>
        </div>
      </section>
    <% end %>
  </article>
</main>
