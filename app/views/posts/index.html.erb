<% content_for :title, "Journal | VybeDeck CMS" %>
<% content_for :description, "The latest posts from VybeDeck CMS" %>

<main class="page-shell">
  <section class="list-heading">
    <div class="shell">
      <p class="eyebrow">VybeDeck CMS</p>
      <h1>Journal</h1>
      <div class="topic-list" aria-label="Topics">
        <% @categories.each do |category| %>
          <%= link_to category.name, category_path(category), class: "topic-chip" %>
        <% end %>
      </div>
    </div>
  </section>

  <section class="content-band">
    <div class="shell post-grid">
      <% if @posts.empty? %>
        <p class="empty-state">No posts published yet. Check back soon.</p>
      <% else %>
        <%= render partial: "post_card", collection: @posts, as: :post %>
      <% end %>
    </div>
    <% if @pagy.pages > 1 %>
      <div class="shell pagy-nav">
        <%= pagy_nav(@pagy) %>
      </div>
    <% end %>
  </section>
</main>
