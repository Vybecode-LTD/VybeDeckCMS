<% content_for :title, "#{@category.name} | VybeDeck CMS" %>
<% content_for :description, "Posts tagged #{@category.name}" %>

<main class="page-shell">
  <section class="list-heading">
    <div class="shell">
      <p class="eyebrow">Topic</p>
      <h1><%= @category.name %></h1>
    </div>
  </section>

  <section class="content-band">
    <div class="shell post-grid">
      <% if @posts.empty? %>
        <p class="empty-state">No posts in this topic yet.</p>
      <% else %>
        <%= render partial: "posts/post_card", collection: @posts, as: :post %>
      <% end %>
    </div>
    <% if @pagy.pages > 1 %>
      <div class="shell pagy-nav">
        <%= pagy_nav(@pagy) %>
      </div>
    <% end %>
  </section>
</main>
