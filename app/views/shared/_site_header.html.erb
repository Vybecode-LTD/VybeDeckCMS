<header class="site-header">
  <div class="shell site-header__inner">
    <%= link_to root_path, class: "brand-mark" do %>
      <span class="brand-mark__sigil">VD</span>
      <span class="brand-mark__name">VybeDeck CMS</span>
    <% end %>

    <nav class="site-nav" aria-label="Primary">
      <% public_nav_pages.each do |page| %>
        <%= link_to page.title, page_path(page) %>
      <% end %>
      <%= link_to "Journal", posts_path %>
      <% if Current.user&.editor? || Current.user&.admin? %>
        <%= link_to "Admin", admin_root_path %>
      <% end %>
      <% if Current.user %>
        <%= link_to "Settings", settings_path %>
      <% else %>
        <%= link_to "Sign in", new_session_path %>
      <% end %>
    </nav>

    <%# Cart toggle — opens the cart drawer %>
    <button class="cart-toggle"
            data-action="click->cart#open"
            aria-label="Open cart (<%= @cart_count %> items)">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none"
           viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="9" cy="21" r="1"/>
        <circle cx="20" cy="21" r="1"/>
        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
      </svg>
      <% if @cart_count > 0 %>
        <span class="cart-toggle__badge" aria-hidden="true"><%= @cart_count %></span>
      <% end %>
    </button>

    <button
      class="theme-toggle"
      aria-label="Toggle colour scheme"
      onclick="(function(btn){
        var html = document.documentElement;
        var current = html.getAttribute('data-color-scheme');
        var isDark = current === 'dark' ||
          (current !== 'light' && window.matchMedia('(prefers-color-scheme: dark)').matches);
        var next = isDark ? 'light' : 'dark';
        html.setAttribute('data-color-scheme', next);
        try { localStorage.setItem('vyb-color-scheme', next); } catch(e) {}
      })(this)"
    >
      <%# Sun icon (shown in dark mode) %>
      <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4"/>
        <line x1="12" y1="2"  x2="12" y2="4"/>
        <line x1="12" y1="20" x2="12" y2="22"/>
        <line x1="4.22" y1="4.22"  x2="5.64" y2="5.64"/>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="2"  y1="12" x2="4"  y2="12"/>
        <line x1="20" y1="12" x2="22" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
        <line x1="18.36" y1="5.64"  x2="19.78" y2="4.22"/>
      </svg>
      <%# Moon icon (shown in light mode) %>
      <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
  </div>
</header>
