<%#
  Locals:
    medium         – a Medium record with file_type == "video" and file attached
    poster_url     – optional URL string for the video poster/thumbnail
    show_download  – boolean, default true; set to false to hide the download link
%>
<% show_download = local_assigns.fetch(:show_download, true) %>
<% poster_url    = local_assigns.fetch(:poster_url, nil) %>

<div class="video-player" data-controller="video-player">

  <%# ── Video screen ── %>
  <div class="video-player__screen"
       data-action="click->video-player#screenClick">
    <% if medium.file.attached? %>
      <video class="video-player__video"
             data-video-player-target="video"
             preload="metadata"
             <%= "poster=\"#{poster_url}\"".html_safe if poster_url %>>
        <source src="<%= url_for(medium.file) %>" type="<%= medium.file.content_type %>">
        Your browser does not support the video element.
      </video>
    <% else %>
      <div class="video-player__no-source">No video file attached.</div>
    <% end %>
  </div>

  <%# ── Controls bar ── %>
  <div class="video-player__bar">

    <%# Play / Pause %>
    <button class="video-player__play-btn"
            data-video-player-target="playBtn"
            data-action="click->video-player#togglePlay"
            aria-label="Play"
            aria-pressed="false"
            type="button">
      <svg class="video-player__icon video-player__icon--play"
           xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
           fill="currentColor" width="18" height="18" aria-hidden="true">
        <path d="M8 5v14l11-7z"/>
      </svg>
      <svg class="video-player__icon video-player__icon--pause"
           xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
           fill="currentColor" width="18" height="18" aria-hidden="true">
        <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
      </svg>
    </button>

    <%# Time %>
    <span class="video-player__time" data-video-player-target="currentTime">–:––</span>

    <%# Scrubber %>
    <input class="video-player__scrubber"
           type="range"
           min="0" max="100" value="0" step="0.1"
           data-video-player-target="scrubber"
           data-action="input->video-player#seek"
           aria-label="Seek">

    <%# Total time %>
    <span class="video-player__time video-player__time--total"
          data-video-player-target="totalTime">–:––</span>

    <%# Right-side controls %>
    <div class="video-player__controls">

      <%# Volume %>
      <label class="video-player__vol-label" aria-label="Volume">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
             fill="currentColor" width="14" height="14" aria-hidden="true">
          <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/>
        </svg>
        <input class="video-player__volume"
               type="range"
               min="0" max="1" step="0.05" value="1"
               data-video-player-target="volume"
               data-action="input->video-player#setVolume"
               aria-label="Volume">
      </label>

      <%# Speed %>
      <select class="video-player__speed"
              data-video-player-target="speed"
              data-action="change->video-player#setSpeed"
              aria-label="Playback speed">
        <option value="0.5">0.5×</option>
        <option value="0.75">0.75×</option>
        <option value="1" selected>1×</option>
        <option value="1.25">1.25×</option>
        <option value="1.5">1.5×</option>
        <option value="2">2×</option>
      </select>

      <%# Download %>
      <% if show_download && medium.file.attached? %>
        <%= link_to rails_blob_path(medium.file, disposition: "attachment"),
                    class: "video-player__download",
                    title: "Download #{medium.file.filename}",
                    aria: { label: "Download #{medium.title}" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
               fill="currentColor" width="15" height="15" aria-hidden="true">
            <path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/>
          </svg>
        <% end %>
      <% end %>

      <%# Fullscreen %>
      <button class="video-player__fullscreen-btn"
              data-video-player-target="fullscreenBtn"
              data-action="click->video-player#toggleFullscreen"
              aria-label="Fullscreen"
              type="button">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
             fill="currentColor" width="16" height="16" aria-hidden="true">
          <path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"/>
        </svg>
      </button>

    </div><%# /.video-player__controls %>
  </div><%# /.video-player__bar %>
</div><%# /.video-player %>
