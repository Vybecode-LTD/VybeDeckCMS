<%# Locals: reply, forum, thread %>
<article class="forum-post" id="reply-<%= reply.id %>">
  <div class="forum-post__avatar">
    <span class="forum-post__initials"><%= reply.author.byline.first.upcase %></span>
  </div>
  <div class="forum-post__content">
    <div class="forum-post__header">
      <strong class="forum-post__author"><%= reply.author.byline %></strong>
      <time class="forum-post__time" datetime="<%= reply.created_at.iso8601 %>">
        <%= reply.created_at.strftime("%b %d, %Y at %H:%M") %>
      </time>
      <% if reply.is_solution? %>
        <span class="solution-badge">✓ Solution</span>
      <% end %>
    </div>
    <div class="forum-post__body trix-content">
      <%= reply.body %>
    </div>
    <div class="forum-post__actions">
      <%= render "community/like_button", reply: reply, forum: forum, thread: thread %>

      <% if Current.user && Current.user != reply.author %>
        <% unless reply.reported? %>
          <div id="report-reply-<%= reply.id %>" class="report-wrap">
            <details class="report-details">
              <summary class="report-link">Report</summary>
              <div class="report-form-inner">
                <%= form_with url: report_community_reply_path(forum.slug, thread.id, reply.id),
                              method: :post, class: "report-form" do |f| %>
                  <%= f.text_area :report_reason,
                        placeholder: "Briefly describe the issue…",
                        rows: 2, class: "report-textarea" %>
                  <%= f.submit "Submit Report", class: "report-submit-btn" %>
                <% end %>
              </div>
            </details>
          </div>
        <% end %>
      <% end %>

      <% if reply.reported? && Current.user&.admin_accessible? %>
        <span class="reported-badge">⚑ Reported</span>
      <% end %>
    </div>
  </div>
</article>
