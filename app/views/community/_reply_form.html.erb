<% if thread.locked? %>
  <div class="locked-notice">
    🔒 This thread is locked and no longer accepting replies.
  </div>
<% elsif Current.user %>
  <%= form_with model: reply,
                url: community_thread_replies_path(forum.slug, thread),
                class: "reply-form",
                id: "reply-form-inner" do |f| %>

    <% if reply.errors.any? %>
      <div class="form-errors">
        <ul>
          <% reply.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="field">
      <%= f.label :body, "Add a reply" %>
      <%= f.rich_text_area :body, class: "trix-content" %>
    </div>

    <div class="form-actions">
      <%= f.submit "Post Reply", class: "button" %>
    </div>
  <% end %>
<% else %>
  <div class="login-prompt">
    <%= link_to "Sign in", new_session_path %> to join the conversation.
  </div>
<% end %>
