<% content_for :title, "Verify your email — VybeDeck CMS" %>

<div class="auth-card">
  <div class="auth-card__header">
    <h1>Check your inbox</h1>
    <p>We sent a verification link to your email address.</p>
  </div>

  <% if flash[:notice].present? %>
    <div class="flash flash--notice" style="margin-bottom:20px"><%= flash[:notice] %></div>
  <% end %>
  <% if flash[:alert].present? %>
    <div class="flash flash--alert" style="margin-bottom:20px"><%= flash[:alert] %></div>
  <% end %>
  <% if flash.now[:alert].present? %>
    <div class="flash flash--alert" style="margin-bottom:20px"><%= flash.now[:alert] %></div>
  <% end %>

  <p style="margin-bottom:24px; color:var(--text-muted); font-size:.9rem;">
    Click the link in the email to verify your address and activate your account.
    The link expires after 48&nbsp;hours.
  </p>

  <details class="resend-details">
    <summary>Didn't receive the email?</summary>
    <div class="resend-form-wrap">
      <%= form_with url: resend_verification_registration_path, method: :post, class: "auth-form" do |f| %>
        <div class="form-field">
          <%= f.label :email, "Your email address" %>
          <%= f.email_field :email,
                required:    true,
                autocomplete: "email",
                placeholder: "you@example.com",
                value:       @expired_email %>
        </div>
        <%= f.submit "Resend verification email", class: "btn btn--full" %>
      <% end %>
    </div>
  </details>

  <div class="auth-footer">
    <%= link_to "Back to sign in", new_session_path %>
  </div>
</div>
