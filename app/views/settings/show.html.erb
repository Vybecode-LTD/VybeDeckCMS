<% content_for :title, "Settings | VybeDeck CMS" %>

<main class="page-shell">
  <div class="shell settings-shell">
    <h1 class="page-heading">Account settings</h1>

    <%# ── Profile ──────────────────────────────────────────────────── %>
    <section class="settings-section" id="profile">
      <h2 class="settings-section__heading">Profile</h2>

      <%= form_with model: @user, url: settings_path, method: :patch,
                    multipart: true, class: "settings-form" do |f| %>

        <% if @user.errors.any? %>
          <div class="flash-inline flash-inline--error">
            <ul>
              <% @user.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="field-unit">
          <%= f.label :display_name, "Display name", class: "field-unit__label" %>
          <%= f.text_field :display_name, class: "field-unit__input",
                placeholder: "yourname", autocomplete: "nickname" %>
          <span class="field-unit__hint">
            Appears on your posts and public profile at
            <% if @user.display_name.present? %>
              <a href="<%= member_path(@user.display_name) %>" class="link"><%= member_path(@user.display_name) %></a>.
            <% else %>
              /members/<em>yourname</em>.
            <% end %>
            Max 50 characters.
          </span>
        </div>

        <div class="field-unit">
          <%= f.label :email_address, "Email address", class: "field-unit__label" %>
          <%= f.email_field :email_address, class: "field-unit__input",
                autocomplete: "email" %>
        </div>

        <div class="field-unit">
          <%= f.label :bio, "Bio", class: "field-unit__label" %>
          <%= f.text_area :bio, class: "field-unit__input", rows: 4,
                maxlength: 280, placeholder: "Tell us about yourself…" %>
          <span class="field-unit__hint">Up to 280 characters.</span>
        </div>

        <div class="field-unit">
          <%= f.label :website_url, "Website", class: "field-unit__label" %>
          <%= f.url_field :website_url, class: "field-unit__input",
                placeholder: "https://example.com", autocomplete: "url" %>
        </div>

        <div class="field-unit">
          <%= f.label :avatar, "Profile picture", class: "field-unit__label" %>
          <% if @user.avatar.attached? %>
            <div class="settings-avatar-preview">
              <%= image_tag url_for(@user.avatar), alt: "", class: "avatar avatar--md" %>
              <span class="field-unit__hint">Upload a new image to replace it.</span>
            </div>
          <% end %>
          <%= f.file_field :avatar, class: "field-unit__file", accept: "image/*" %>
          <span class="field-unit__hint">JPEG, PNG, GIF, or WebP. Max 10&nbsp;MB.</span>
        </div>

        <div class="settings-actions">
          <%= f.submit "Save profile", class: "btn" %>
        </div>
      <% end %>
    </section>

    <%# ── Change password ──────────────────────────────────────────── %>
    <section class="settings-section" id="security">
      <h2 class="settings-section__heading">Change password</h2>

      <%= form_with url: update_password_settings_path, method: :patch,
                    class: "settings-form" do |f| %>

        <div class="field-unit">
          <%= f.label :current_password, "Current password", class: "field-unit__label" %>
          <%= f.password_field :current_password, class: "field-unit__input",
                autocomplete: "current-password", id: "current_password" %>
        </div>

        <div class="field-unit">
          <%= f.label :password, "New password", class: "field-unit__label" %>
          <%= f.password_field :password, class: "field-unit__input",
                autocomplete: "new-password", id: "new_password" %>
          <span class="field-unit__hint">At least 12 characters.</span>
        </div>

        <div class="field-unit">
          <%= f.label :password_confirmation, "Confirm new password", class: "field-unit__label" %>
          <%= f.password_field :password_confirmation, class: "field-unit__input",
                autocomplete: "new-password", id: "password_confirmation" %>
        </div>

        <div class="settings-actions">
          <%= f.submit "Change password", class: "btn" %>
        </div>
      <% end %>
    </section>

    <%# ── Danger zone ──────────────────────────────────────────────── %>
    <section class="settings-section settings-section--danger" id="session">
      <h2 class="settings-section__heading">Session</h2>
      <p class="settings-section__desc">Sign out of your account on this device.</p>
      <%= button_to "Sign out", session_path, method: :delete, class: "btn btn--secondary" %>
    </section>
  </div>
</main>
