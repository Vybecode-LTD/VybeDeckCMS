<!DOCTYPE html>
<html data-color-scheme="">
  <head>
    <title><%= content_for(:title) || "VybeDeck CMS" %></title>
    <% if content_for?(:description) %>
      <meta name="description" content="<%= h content_for(:description) %>">
    <% end %>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%# ── Canonical ────────────────────────────────────────────────────── %>
    <% _canonical = content_for?(:canonical_url) ? content_for(:canonical_url) : (request.base_url + request.path) %>
    <link rel="canonical" href="<%= h _canonical %>">

    <%# ── Open Graph ───────────────────────────────────────────────────── %>
    <% _og_title = content_for?(:title) ? content_for(:title) : "VybeDeck CMS" %>
    <% _og_desc  = content_for?(:description) ? content_for(:description) : "" %>
    <% _og_type  = content_for?(:og_type) ? content_for(:og_type) : "website" %>
    <meta property="og:title"       content="<%= h _og_title %>">
    <meta property="og:description" content="<%= h _og_desc %>">
    <meta property="og:url"         content="<%= h _canonical %>">
    <meta property="og:type"        content="<%= h _og_type %>">
    <meta property="og:site_name"   content="VybeDeck CMS">
    <% if content_for?(:og_image) %>
      <meta property="og:image"     content="<%= h content_for(:og_image) %>">
    <% end %>

    <%# ── Twitter Card ─────────────────────────────────────────────────── %>
    <meta name="twitter:card"        content="summary_large_image">
    <meta name="twitter:title"       content="<%= h _og_title %>">
    <meta name="twitter:description" content="<%= h _og_desc %>">
    <% if content_for?(:og_image) %>
      <meta name="twitter:image"    content="<%= h content_for(:og_image) %>">
    <% end %>

    <%# ── JSON-LD ──────────────────────────────────────────────────────── %>
    <% if content_for?(:json_ld) %>
      <script type="application/ld+json" nonce="<%= content_security_policy_nonce %>">
        <%= content_for(:json_ld) %>
      </script>
    <% end %>
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="VybeDeck CMS">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= turbo_refreshes_with method: :morph, scroll: :preserve %>

    <%= yield :head %>
    <%= VybeDeck::Plugin::Registry.render_hook(:inject_head) %>
    <% _theme_css = active_theme_css %>
    <% if _theme_css.present? %>
      <style id="theme-override"><%= raw _theme_css %></style>
    <% end %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <%# No-flash theme: reads localStorage before first paint to prevent color flicker %>
    <%# nonce attribute required by the Content Security Policy script-src directive %>
    <script nonce="<%= content_security_policy_nonce %>">
      (function() {
        var stored = null;
        try { stored = localStorage.getItem("vyb-color-scheme"); } catch(e) {}
        if (stored === "dark" || stored === "light") {
          document.documentElement.setAttribute("data-color-scheme", stored);
        }
      })();
    </script>
  </head>

  <body data-controller="cart" data-action="keydown->cart#keydown@window">
    <%# Turbo Stream subscription for real-time notification bell updates %>
    <% if Current.user %>
      <%= turbo_stream_from "notifications_user_#{Current.user.id}" %>
    <% end %>
    <%# Impersonation warning — only visible when an admin is browsing as another user %>
    <% if impersonating? %>
      <div class="impersonation-banner">
        <span class="impersonation-banner__label">
          &#9888; Impersonating <strong><%= Current.user&.byline %></strong>
        </span>
        <%= button_to "Exit impersonation",
              admin_impersonation_path,
              method: :delete,
              class: "button button--sm button--danger",
              data: { turbo_confirm: "End impersonation and return to your admin account?" } %>
      </div>
    <% end %>

    <%= render "shared/site_header" %>

    <% if notice.present? %>
      <div class="shell" style="padding-top:12px">
        <div class="flash flash--notice"><%= notice %></div>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="shell" style="padding-top:12px">
        <div class="flash flash--alert"><%= alert %></div>
      </div>
    <% end %>

    <%= yield %>

    <%= render "shared/site_footer" %>

    <%# ── Cart sidebar drawer ─────────────────────────────────────────────── %>
    <%# Overlay (click to close) %>
    <div class="cart-overlay"
         data-cart-target="overlay"
         data-action="click->cart#close"
         aria-hidden="true"></div>

    <%# Sliding panel %>
    <aside class="cart-panel"
           data-cart-target="panel"
           aria-label="Shopping cart"
           aria-hidden="true"
           tabindex="-1">
      <div class="cart-panel__header">
        <h2 class="cart-panel__title">
          Cart
          <span class="cart-badge" id="cart-badge"><%= @cart_count %></span>
        </h2>
        <button class="cart-close-btn"
                data-action="click->cart#close"
                aria-label="Close cart">✕</button>
      </div>
      <div class="cart-panel__body" id="cart-panel-body">
        <%= render "carts/cart_contents",
              cart: @cart, cart_items: @cart_items %>
      </div>
    </aside>
    <%= VybeDeck::Plugin::Registry.render_hook(:inject_footer) %>
  </body>
</html>
