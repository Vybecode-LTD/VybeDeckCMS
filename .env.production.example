# Railway environment variable reference.
# Copy to Railway → Variables and fill in real values before first deploy.
# NEVER commit a file containing actual secrets.

# ── Rails core ────────────────────────────────────────────────────────────────
# Generate with: ruby -e "require 'securerandom'; puts SecureRandom.hex(64)"
SECRET_KEY_BASE=REPLACE_WITH_SECRET_KEY_BASE

# bin/rails credentials:edit generates this; Railway must have the value so the
# app can decrypt credentials.yml.enc at boot.
RAILS_MASTER_KEY=REPLACE_WITH_MASTER_KEY

RAILS_ENV=production
RAILS_LOG_TO_STDOUT=true

# ── Database ──────────────────────────────────────────────────────────────────
# Railway injects DATABASE_URL automatically when a Postgres plugin is attached.
# If it is not auto-injected, set it manually:
# DATABASE_URL=postgresql://user:password@host:5432/vybedeck_cms_production

# ── Admin seed credentials ────────────────────────────────────────────────────
# db:seed reads these to create the first admin account on a fresh deploy.
# Change ADMIN_PASSWORD immediately after first sign-in.
ADMIN_EMAIL=admin@yourdomain.example
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
ADMIN_DISPLAY_NAME=VybeDeck Admin

# ── Active Storage — Cloudflare R2 ────────────────────────────────────────────
# Create an R2 bucket in Cloudflare → R2 → Create bucket.
# Create an API token with R2 edit permissions.
# Your account ID is in the Cloudflare dashboard URL.
CLOUDFLARE_ACCOUNT_ID=REPLACE_WITH_CF_ACCOUNT_ID
CLOUDFLARE_R2_ACCESS_KEY_ID=REPLACE_WITH_R2_ACCESS_KEY_ID
CLOUDFLARE_R2_SECRET_ACCESS_KEY=REPLACE_WITH_R2_SECRET_ACCESS_KEY
CLOUDFLARE_R2_BUCKET=vybedeck-cms-production

# ── Email (Resend REST API) ───────────────────────────────────────────────────
# Create an API key at resend.com/api-keys.
# Verify your sending domain at resend.com/domains first.
RESEND_API_KEY=re_REPLACE_WITH_RESEND_API_KEY
# The From address — must use a verified Resend domain.
ACTION_MAILER_FROM=no-reply@yoursendingdomain.example
# Your public hostname — used to build links in emails.
RAILS_HOST=yourdomain.example

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE
STRIPE_SECRET_KEY=sk_live_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_REPLACE

# ── Anthropic / Claude AI ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-REPLACE

# ── Solid Queue (set in railway.toml — listed here for reference) ─────────────
# SOLID_QUEUE_IN_PUMA=true  ← already set in railway.toml, do not duplicate here.

# ── Port ─────────────────────────────────────────────────────────────────────
# PORT=80  ← already set in railway.toml, do not duplicate here.
